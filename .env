# ─────────────────────────────────────────────
# Django settings
# ─────────────────────────────────────────────
SECRET_KEY=tu_clave_secreta_aqui
DEBUG=True

# Dirección donde Django escuchará dentro del contenedor
DJANGO_ALLOWED_HOSTS=*

# ─────────────────────────────────────────────
# Database settings (PostgreSQL)
# ─────────────────────────────────────────────
DB_NAME=portgas
DB_USER=portgas
DB_PASSWORD=portgas
DB_HOST=db
DB_PORT=5432

# ─────────────────────────────────────────────
# Static files
# ─────────────────────────────────────────────
STATIC_ROOT=/app/staticfiles


DJANGO_ALLOWED_HOSTS=*,localhost,127.0.0.1,0.0.0.0
